# Local agent/editor state — never commit
.claude/

# Credentials and secrets — never commit
scripts/support/config/config.json
scripts/alpha/config/config.json
scripts/alpha/config/config.json.*
**/config/config.json
**/config/config.json.*
*.env
.env.*

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
.eggs/
*.egg

# Virtual environments
.venv/
venv/
env/

# Logs
scripts/support/logs/
*.log
*.log.jsonl
*.log.gz
*.jsonl

# Cache files
scripts/cache/
scripts/support/cache/
*.zip
*.gz
*.parquet

# IDE
.idea/
.vscode/
*.iml

# OS
.DS_Store
Thumbs.db

# Stray run-log dumps (redirect targets, not source)
/test_log.txt
/test_log2.txt
/test_daemon_log.txt

# Vendored third-party Kometa overlay asset bundles (PNGs/yml dumped under the
# cache factory dir) — not source; keep out of commits.
scripts/managers/factories/cache/kometa-*/

# Generated TV-franchise catalog (Wikidata spin-off graph). DIFF-REVIEW before shipping:
# the raw generator output carries noise (loosely-linked cartoons, regional reality versions)
# the design says to prune in review — never auto-commit. Regenerate with
# `python -m scripts.support.tools.generate_tv_franchises`; force-add a vetted copy when ready.
scripts/managers/services/plex/playlists/tv_franchises.generated.json

# Vendored TRaSH guide cache (re-fetched by arr_trash_fetch.py) — not source.
scripts/support/profiles/trash/

# Pre-apply profile snapshots (auto-backup written before a rebuild applies) — generated.
scripts/support/profiles/**/_pre_apply_snapshot/
